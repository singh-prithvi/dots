# ============================================================================
# SECTION 4: INPUT FUNCTIONS
# ============================================================================
#
# There is exactly ONE function that reads a single keypress (read_key)
# and exactly ONE function that reads a free-text line (prompt_line).
# Every prompt, menu, and confirmation in this app is built on top of
# these two — no scattered `read -p` calls reinventing the same thing
# slightly differently in five places, which is exactly what you would
# have done given the chance.

# Put the terminal into "raw-ish" (cbreak) mode: keys are delivered to us
# one at a time, immediately, without waiting for Enter, and without the
# terminal echoing them back at us. This is what makes arrow-key/hjkl
# navigation possible at all — canonical mode would buffer every keypress
# until the user hits Enter, which is not the vibe we're going for.
#
# NOTE: this is also the reentry point after an external program (nvim,
# your editor of choice, whatever) has trashed the whole screen with its
# own UI. `clear` here is the ONE deliberate exception to "never clear
# after startup" — the editor painted content we have zero knowledge of
# and zero way to diff against, so there is nothing smart to do except
# wipe it and start over. If you "clean this up" by deleting the clear,
# enjoy your new career debugging garbled leftover Vim splash screens.
enter_raw_mode() {
        ORIGINAL_STTY=$(stty -g 2>/dev/null) || true
        stty -icanon -echo min 1 time 0 2>/dev/null || true
        tput civis 2>/dev/null || true # hide the cursor while we're driving menus
        clear
}

# Put the terminal back the way we found it. Called on every exit path —
# normal quit, error, or Ctrl+C — because leaving someone's terminal
# stuck in raw mode is the kind of thing that ruins an evening, and
# yours has had enough of those already.
restore_terminal_mode() {
        if [[ -n "$ORIGINAL_STTY" ]]; then
                stty "$ORIGINAL_STTY" 2>/dev/null || true
        fi
        tput cnorm 2>/dev/null || true
}

# Read exactly one logical keypress and classify it. Returns one of:
#   UP DOWN LEFT RIGHT ENTER ESCAPE RESIZE  or  KEY:<char> for anything else.
#
# Arrow keys don't send a single byte — they send an escape sequence
# (ESC, then '[', then a letter), a convention terminals have followed
# since the VT100. We read the ESC, then race a very short timeout
# against a second read: if two more bytes show up almost instantly,
# it was an arrow key; if nothing follows, it was just a lonely Esc,
# not unlike your commitment to any given hobby.
#
# RESIZE handling lives here too. When SIGWINCH fires mid-read (someone
# dragged the terminal edge), bash interrupts this blocking `read` and
# runs the trap, which just sets WINDOW_RESIZED=1 and gets out of the
# way. We check that flag FIRST, before trying to interpret whatever
# `read` handed back — because an interrupted read can leave `key` empty,
# and an empty key is what ENTER looks like below. Skip this check and a
# window resize starts silently firing menu selections for you. You do
# not want that particular surprise.
read_key() {
        local key seq
        IFS= read -rsn1 key || true

        if ((WINDOW_RESIZED)); then
                WINDOW_RESIZED=0
                echo "RESIZE"
                return 0
        fi

        case "$key" in
        $'\x1b')
                seq=""
                if IFS= read -rsn2 -t 0.01 seq 2>/dev/null; then
                        case "$seq" in
                        '[A') echo "UP" ;;
                        '[B') echo "DOWN" ;;
                        '[C') echo "RIGHT" ;;
                        '[D') echo "LEFT" ;;
                        *) echo "ESCAPE" ;;
                        esac
                else
                        # Escape always means go back. Just like Vim. Except
                        # without the mild existential dread of wondering whether
                        # you'll ever actually leave.
                        echo "ESCAPE"
                fi
                ;;
        $'\r' | $'\n' | '')
                echo "ENTER"
                ;;
        *)
                echo "KEY:$key"
                ;;
        esac

        return 0
}

# Read one line of free text (commit messages, paths, etc).
#
# BUG YOU FOUND (image 3 — `^[j^[^[^[^[q` sitting in your commit message):
# this used to hand the terminal back to cooked mode and call the `read`
# builtin. Cooked mode has no idea what "Esc" means — it's not a control
# character to bash's line editor, it's just a byte, so pressing Esc (and
# then more keys, panicking) got typed into the message VERBATIM. Every
# other screen in this app treats Esc as "go back." This one silently
# didn't, and nothing on screen told you that.
#
# Fixed by building the line ourselves, one read_key() at a time, in the
# SAME raw mode everything else already runs in — so this function now
# understands the same three keys as every menu: Enter submits, Esc
# cancels (returns empty — every caller already treats an empty result
# as "cancelled", so nothing downstream needed to change), and Backspace
# erases the last character both from the buffer and from the screen.
# Because we no longer drop into cooked mode, callers must NOT wrap this
# in restore_terminal_mode/enter_raw_mode anymore — that would just turn
# the cursor's line editing back over to the terminal and reintroduce
# the exact bug this fixes. Search for prompt_line's call sites; if one
# of them still bookends it with restore/enter, you undid this.
prompt_line() {
        local prompt="$1"
        local input="" key ch

        printf '  %s' "$prompt"

        while true; do
                key=$(read_key)
                case "$key" in
                ENTER)
                        break
                        ;;
                ESCAPE)
                        input=""
                        break
                        ;;
                RESIZE)
                        # Not much we can salvage mid-typing on a resize —
                        # clearing and reprinting is the honest option
                        # rather than leaving a half-corrupted prompt.
                        clear
                        printf '  %s%s' "$prompt" "$input"
                        ;;
                'KEY:'$'\x7f' | 'KEY:'$'\x08')
                        if [[ -n "$input" ]]; then
                                input="${input%?}"
                                printf '\b \b'
                        fi
                        ;;
                KEY:*)
                        ch="${key#KEY:}"
                        input+="$ch"
                        printf '%s' "$ch"
                        ;;
                *)
                        : # arrows etc. mean nothing to a text field, ignore them
                        ;;
                esac
        done

        echo
        printf '%s' "$input"
}

# Yes/no confirmation, built on read_key so there's no second copy of the
# "read a key from the user" logic anywhere in this file. Defaults to
# "no" on anything but an explicit y/Y, since this guards destructive
# operations (restore, checkout) where the safe default matters more
# than saving a keystroke — a rare moment of restraint from you.
# Usage: if confirm "Are you sure?"; then ... fi
confirm() {
        local prompt="$1" key
        printf '  %s%s%s %s %s[y/N]%s ' "$C_YELLOW" "$ICON_WARN" "$C_RESET" "$prompt" "$C_DIM" "$C_RESET"
        while true; do
                key=$(read_key)
                case "$key" in
                KEY:y | KEY:Y)
                        echo
                        return 0
                        ;;
                KEY:n | KEY:N | ENTER | ESCAPE)
                        echo
                        return 1
                        ;;
                RESIZE)
                        # Best-effort: we can't redraw content we no longer
                        # have, but re-showing the question beats leaving a
                        # corrupted line up while you wait for an answer.
                        clear
                        printf '  %s%s%s %s %s[y/N]%s ' "$C_YELLOW" "$ICON_WARN" "$C_RESET" "$prompt" "$C_DIM" "$C_RESET"
                        ;;
                *) : ;; # anything else: keep waiting, don't guess — unlike you at 3am with rm -rf
                esac
        done
}

# Wait for any keypress before redrawing whatever comes next. Gives the
# user a moment to actually read the output of the action they just ran,
# a courtesy you rarely extend to yourself in git commit messages.
#
# NOTE ON WHERE THE "ERASE STALE STUFF" JOB LIVES NOW: it used to live
# here, running once the screen was already fully drawn — which is
# exactly why a stale, taller previous screen (the full Git menu, in
# your screenshots) was still visible the ENTIRE TIME an action screen
# was busy prompting you for something, right up until you got here.
# That job now happens once, up front, in begin_action_screen — before
# a single line of the new screen's content gets drawn — instead of
# being an afterthought bolted on at the exit. This function's only job
# is waiting, the way its name has claimed all along.
pause_for_return() {
        echo
        printf '  %sPress any key to continue...%s' "$C_DIM" "$C_RESET"
        local key
        while true; do
                key=$(read_key)
                if [[ "$key" == "RESIZE" ]]; then
                        # Same tradeoff as confirm()'s RESIZE handling: the
                        # action output above is gone, but staring at a
                        # garbled screen forever is worse than an honest
                        # blank one asking you to press a key.
                        clear
                        printf '  %sPress any key to continue...%s' "$C_DIM" "$C_RESET"
                        continue
                fi
                break
        done
        echo
}

# Run an external, full-screen program (an editor, basically) with the
# terminal restored to normal mode, then put our raw mode back afterward.
# Without this, launching nvim while we're sitting in -icanon/-echo with
# the cursor hidden would make for a very confusing few seconds — and
# you'd file it as "bash is broken" instead of reading your own code.
run_external_program() {
        restore_terminal_mode
        local status=0
        "$@" || status=$?
        enter_raw_mode
        return "$status"
}

# Find the best available editor. Preference order: the user's own
# $EDITOR/$VISUAL, then a fallback chain from "full-featured" to
# "definitely installed everywhere." Centralized here so nothing else
# in this file hardcodes an editor name — because we both know which
# editor you'd have hardcoded, and it would've started a flame war.
resolve_editor() {
        local candidate
        for candidate in "${EDITOR:-}" "${VISUAL:-}" nvim vim micro nano; do
                [[ -z "$candidate" ]] && continue
                if command -v "$candidate" >/dev/null 2>&1; then
                        printf '%s' "$candidate"
                        return 0
                fi
        done
        return 1
}

