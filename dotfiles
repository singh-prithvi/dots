# ============================================================================
# SECTION 12: MAIN LOOP
# ============================================================================

# Restore the terminal and exit. Every exit path in this app — the Exit
# menu item, pressing q, an unhandled error, or Ctrl+C — routes through
# here, so the person's shell is never left in a broken state.
cleanup_and_exit() {
        local code="${1:-0}"
        restore_terminal_mode
        clear
        echo
        echo "  ${C_DIM}$(random_exit_message)${C_RESET}"
        echo
        exit "$code"
}

# Beautiful errors. An uncaught failure anywhere in this script lands
# here instead of dumping a raw Bash stack trace on someone — a C++
# segfault at least gives you a core dump; the least Bash can do is give
# you a sentence.
on_error() {
        local exit_code=$? line_no="${1:-unknown}"
        restore_terminal_mode
        echo
        print_error "Something went wrong (exit code ${exit_code}) near line ${line_no}."
        print_info "This shouldn't happen — please report it if it keeps occurring."
        exit "$exit_code"
}

main() {
        if [[ ! -t 0 || ! -t 1 ]]; then
                echo "dotfiles: this is an interactive terminal application — please run it in a terminal." >&2
                exit 1
        fi

        trap 'on_error $LINENO' ERR
        trap 'cleanup_and_exit 130' INT
        trap 'cleanup_and_exit 0' TERM
        trap 'restore_terminal_mode' EXIT

        load_app_settings
        load_tracked_paths
        apply_theme "$THEME_NAME"
        enter_raw_mode

        main_menu
}

# Only run main if this script is executed directly, not sourced. This
# makes it possible to source the file (e.g. from a test harness) and
# call individual functions without kicking off the interactive app.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
        main "$@"
fi
