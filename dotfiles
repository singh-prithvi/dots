        begin_action_screen "Tracked Files › Reload"
        load_tracked_paths
        print_success "Configuration reloaded from $(shorten_path "$PATHS_CONFIG_FILE")"
        pause_for_return
}

tracked_files_menu() {
        while true; do
                show_interactive_menu "Tracked Files" 0 \
