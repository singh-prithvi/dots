settings_repository_path() {
        begin_action_screen "Settings › Repository path"
        echo "  Current: $(shorten_path "$REPO_DIR")"
        echo

        if confirm "Change the repository path?"; then
                local new_path
                new_path=$(prompt_line "New path (e.g. ~/dots): ")
                new_path="${new_path/#\~/$HOME}" # bash won't expand a literal ~ for us here, it's not psychic, unlike you'd apparently like it to be

                if [[ -z "$new_path" ]]; then
                        print_warning "No path entered — keeping the current one."
                else
                        REPO_DIR="$new_path"
                        save_app_settings
                        print_success "Repository path updated to $(shorten_path "$REPO_DIR")"
                fi
        fi
        pause_for_return
}

open_in_file_manager() {
        local path="$1"
        if command -v xdg-open >/dev/null 2>&1; then
                (xdg-open "$path" >/dev/null 2>&1 &) || true
                print_success "Opened $(shorten_path "$path") in your file manager."
        else
                print_warning "xdg-open not found. Path: $(shorten_path "$path")"
        fi
}

settings_open_repository() {
        begin_action_screen "Settings › Open repository"
        open_in_file_manager "$REPO_DIR"
        pause_for_return
}

settings_open_config_dir() {
        begin_action_screen "Settings › Open config directory"
        open_in_file_manager "$APP_CONFIG_DIR"
        pause_for_return
}

settings_theme_menu() {
        while true; do
                show_interactive_menu "Settings › Theme" 0 "Default" "Catppuccin Mocha" "Back"

                case "$MENU_RESULT" in
                0)
                        THEME_NAME="default"
                        apply_theme "$THEME_NAME"
                        save_app_settings
                        begin_action_screen "Settings › Theme"
                        print_success "Theme set to Default."
                        pause_for_return
                        ;;
                1)
                        THEME_NAME="mocha"
                        apply_theme "$THEME_NAME"
                        save_app_settings
                        begin_action_screen "Settings › Theme"
                        print_success "Theme set to Catppuccin Mocha."
                        pause_for_return
                        ;;
                2 | BACK) return ;;
                esac
        done
}

show_about_screen() {
        begin_action_screen "About"
        echo "  ${C_BOLD}dotfiles${C_RESET} ${C_DIM}v${APP_VERSION}${C_RESET}"
        echo
        echo "  Keeps the config files in \$HOME in sync with a git repository,"
        echo "  so you don't have to remember which dozen directories you"
        echo "  actually care about. That's what Tracked Files is for."
        echo
        echo "  Repository: $(shorten_path "$REPO_DIR")"
        echo "  Config:     $(shorten_path "$APP_CONFIG_DIR")"
        echo
        echo "  ${C_DIM}Built with Bash, ANSI escape codes, and a healthy respect"
        echo "  for how much can go wrong when rm -rf is one typo away.${C_RESET}"
        pause_for_return
}

settings_menu() {
        while true; do
                show_interactive_menu "Settings" 0 \
                        "Repository path" \
                        "Open repository" \
                        "Open config directory" \
                        "Theme" \
                        "About" \
                        "Back"

                case "$MENU_RESULT" in
                0) settings_repository_path ;;
                1) settings_open_repository ;;
                2) settings_open_config_dir ;;
                3) settings_theme_menu ;;
                4) show_about_screen ;;
                5 | BACK) return ;;
                esac
        done
}

# --- Main -----------------------------------------------------------------------

main_menu() {
        local -a items=(
                "Sync dotfiles to repository"
                "Restore dotfiles to system"
                "Git"
                "Tracked files"
                "Settings"
                "Exit"
        )

        while true; do
                show_interactive_menu "DOTFILES MANAGER" 1 "${items[@]}"

                case "$MENU_RESULT" in
                0) action_sync ;;
                1) action_restore ;;
                2) git_menu ;;
                3) tracked_files_menu ;;
                4) settings_menu ;;
                5) cleanup_and_exit 0 ;;
                BACK) : ;; # nowhere further back to go from the main menu — the buck stops here, unlike your project deadlines
                esac
        done
}

# ============================================================================
# SECTION 12: MAIN LOOP
# ============================================================================

# Restore the terminal and exit. Every exit path in this app — the Exit
# menu item, pressing q, an unhandled error, or Ctrl+C — routes through
# here, so the person's shell is never left in a broken state, which is
# more consideration than you show your own future self.
#
# The `clear` here is fine and stays — it's the terminal's LAST frame,
# ever, for this session. That's the one and only other place, besides
# startup and the post-editor return in enter_raw_mode, where blanking
# the screen is the correct call instead of the lazy one.
cleanup_and_exit() {
        local code="${1:-0}"
        restore_terminal_mode
        clear
        echo
        echo "  ${C_DIM}$(random_exit_message)${C_RESET}"
        echo
        exit "$code"
}

# Beautiful errors. An uncaught failure anywhere in this script lands
# here instead of dumping a raw Bash stack trace on someone — a C++
# segfault at least gives you a core dump; the least Bash can do is give
# you a sentence, which is more closure than most of your relationships.
on_error() {
        local exit_code=$? line_no="${1:-unknown}"
        restore_terminal_mode
        echo
        print_error "Something went wrong (exit code ${exit_code}) near line ${line_no}."
        print_info "This shouldn't happen — please report it if it keeps occurring."
        exit "$exit_code"
}

main() {
        if [[ ! -t 0 || ! -t 1 ]]; then
                echo "dotfiles: this is an interactive terminal application — please run it in a terminal." >&2
                exit 1
        fi

        trap 'on_error $LINENO' ERR
        trap 'cleanup_and_exit 130' INT
        trap 'cleanup_and_exit 0' TERM
        trap 'restore_terminal_mode' EXIT
        # This one didn't exist before, which is exactly why resizing the
        # terminal mid-session used to leave rules and titles computed for
        # a width that no longer existed. WINCH just flips a flag — it does
        # NOT touch the terminal directly from inside a signal handler,
        # because doing real I/O from a trap is how you get a genuinely
        # haunted script. read_key notices the flag, reports a "RESIZE"
        # pseudo-key, and every read_key() call site now knows what to do
        # with one. Go check them if you don't believe me.
        trap 'WINDOW_RESIZED=1' WINCH

        load_app_settings
        load_tracked_paths
        apply_theme "$THEME_NAME"
        # enter_raw_mode owns the ONE startup `clear` — see its comment
        # for why it also doubles as the post-editor repaint trigger.
        enter_raw_mode

        main_menu
}

# Only run main if this script is executed directly, not sourced. This
# makes it possible to source the file (e.g. from a test harness) and
# call individual functions without kicking off the interactive app —
# assuming you ever write a test harness, which, let's be honest.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
        main "$@"
fi
