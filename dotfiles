#!/usr/bin/env bash
#
# dotfiles — an interactive terminal application for managing dotfiles.
#
# Keeps the "real" configuration living in $HOME / ~/.config in sync with
# a git repository (default: ~/dots), through a lazygit-style menu instead
# of a wall of numbered prompts.
#
#   Sync     $HOME        -> repository
#   Restore  repository   -> $HOME
#
# Author: generated for Prithvi.
# License: do whatever you want with it.
#
# ============================================================================
# SECTION 1: CONSTANTS
# ============================================================================
#
#   -E : ERR trap is inherited by functions and subshells, not just the
#        top-level script. Without this, a failure inside a function you
#        called from an `if` would be silently swallowed.
#   -e : exit immediately if a command fails, UNLESS that command is part
#        of a tested construct (if/while/until/&&/||). This is what lets
#        us handle expected failures (like "nothing to commit") gracefully
#        instead of the whole program falling over.
#   -u : referencing an unset variable is an error, not an empty string.
#   -o pipefail : a pipeline's exit status is that of its last *failing*
#        command, not just its last command.
#
# Together these are Bash's version of wearing a seatbelt, a helmet, and
# also texting your mom before a road trip. A little paranoid. Correct.
set -Eeuo pipefail

