        echo
        echo "  ${C_BOLD}Files${C_RESET}"
        if ((${#FILES[@]} == 0)); then
                echo "    ${C_DIM}(none)${C_RESET}"
        else
                local f
                for f in "${FILES[@]}"; do
                        echo "    ${ICON_FILE} ~/$f"
                done
        fi

        echo
