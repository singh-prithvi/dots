view_tracked_paths() {
        begin_action_screen "Tracked Files › View"

        echo "  ${C_BOLD}Directories${C_RESET}"
        if ((${#DIRECTORIES[@]} == 0)); then
                echo "    ${C_DIM}(none)${C_RESET}"
        else
                local d
                for d in "${DIRECTORIES[@]}"; do
                        echo "    ${ICON_DIR} ~/$d"
                done
        fi

        echo
        echo "  ${C_BOLD}Files${C_RESET}"
        if ((${#FILES[@]} == 0)); then
                echo "    ${C_DIM}(none)${C_RESET}"
        else
                local f
                for f in "${FILES[@]}"; do
                        echo "    ${ICON_FILE} ~/$f"
                done
        fi

        echo
        print_info "Config file: $(shorten_path "$PATHS_CONFIG_FILE")"
        pause_for_return
}

edit_tracked_paths() {
        begin_action_screen "Tracked Files › Edit"
        ensure_paths_config_exists

        local editor
        if ! editor=$(resolve_editor); then
                print_error "No editor found. Set \$EDITOR, or install nvim/vim/micro/nano."
                pause_for_return
                return
        fi

        print_info "Opening $(shorten_path "$PATHS_CONFIG_FILE") with '${editor}'..."
        run_external_program "$editor" "$PATHS_CONFIG_FILE"

        load_tracked_paths
        print_success "Tracked paths reloaded."
        pause_for_return
}

reload_tracked_paths() {
        begin_action_screen "Tracked Files › Reload"
        load_tracked_paths
        print_success "Configuration reloaded from $(shorten_path "$PATHS_CONFIG_FILE")"
        pause_for_return
}

tracked_files_menu() {
        while true; do
                show_interactive_menu "Tracked Files" 0 \
                        "View tracked paths" \
                        "Edit tracked paths" \
                        "Reload configuration" \
                        "Back"

                case "$MENU_RESULT" in
                0) view_tracked_paths ;;
                1) edit_tracked_paths ;;
                2) reload_tracked_paths ;;
                3 | BACK) return ;;
                esac
        done
}

