        *)
                C_ACCENT=$'\033[36m'
                C_GREEN=$'\033[32m'
                C_RED=$'\033[31m'
                C_YELLOW=$'\033[33m'
                C_BLUE=$'\033[34m'
                ;;
        esac

        return 0
}

# ============================================================================
# SECTION 3: UTILITY FUNCTIONS
# ============================================================================

# Terminal width, falling back to 80 columns if it can't be determined
# (e.g. no controlling terminal). 80 columns: the default width of your
# self-esteem when a build fails.
term_width() {
        tput cols 2>/dev/null || echo 80
}

# Print a horizontal rule spanning the terminal width.
#
# BUG YOU FOUND (the "dividers" in your screenshots): this used to end with
# a bare `\n`. If the terminal had just gotten narrower, or the previous
# line at this exact row was drawn at a wider width, the tail end of the
# OLD rule kept sitting there past where the NEW, shorter rule stopped —
# because nothing ever told the terminal "and erase whatever's left on
# this line." `tput el` (erase-to-end-of-line) does exactly that, and it
# has to run AFTER the rule is drawn but BEFORE the newline, while the
# cursor is still sitting on this row and not the next one.
# Usage: print_rule "─"
print_rule() {
        local char="${1:--}"
        local width
        width=$(term_width)
        printf '%*s' "$width" '' | tr ' ' "$char"
        tput el
        printf '\n'
}

# Print text centered within the terminal width, in an optional color.
# Centering text is the one thing in this entire project that's actually
# balanced.
#
# BUG YOU FOUND ("GitMANAGER", "CommitER"): centered text starts at a
# DIFFERENT column depending on how long it is — "DOTFILES MANAGER" starts
# further left than "Git" does, because they're both centered around the
# same midpoint but have different lengths. Without erasing this row
# before moving on, whatever the LAST title left behind outside the new
# title's footprint just... stays there, mashed up against the new one.
# Same `tput el`-before-newline fix as print_rule, same reason.
# Usage: print_centered "some text" "$C_BOLD$C_ACCENT"
print_centered() {
        local text="$1"
        local color="${2:-}"
        local width padding
        width=$(term_width)
        padding=$(((width - ${#text}) / 2))
        ((padding < 0)) && padding=0
        printf '%*s%s%s%s' "$padding" '' "$color" "$text" "$C_RESET"
        tput el
        printf '\n'
}

# Replace a leading $HOME with ~, purely for display. Defined once so the
# same shortening logic isn't retyped in a dozen different echo statements
# (and so it's easy to change later if we ever want, say, full paths —
# something you will absolutely ask for in six months and forget you're
# the one who removed it).
shorten_path() {
        printf '%s' "${1/#$HOME/~}"
}

# Standardized message helpers. Every screen in the app uses these instead
# of ad-hoc `echo`, so the look-and-feel stays consistent by construction —
# the one form of consistency you've managed to enforce anywhere.
print_success() { echo "  ${C_GREEN}${ICON_OK}${C_RESET} $1"; }
print_error() { echo "  ${C_RED}${ICON_ERR}${C_RESET} $1" >&2; }
print_warning() { echo "  ${C_YELLOW}${ICON_WARN}${C_RESET} $1"; }
print_info() { echo "  ${C_BLUE}${ICON_ARROW}${C_RESET} $1"; }

# Print a two-count-plus-errors summary block, shared by sync and restore
# so the formatting logic exists in exactly one place, instead of the two
# slightly-different copy-pasted places you'd have left it in.
# Usage: print_summary "Sync summary" "Directories synced" "$n" "Files copied" "$m" "$errors"
print_summary() {
        local title="$1" label_a="$2" count_a="$3" label_b="$4" count_b="$5" errors="$6"
        echo
        print_rule "─"
        echo "  ${C_BOLD}${title}${C_RESET}"
        echo "  ${label_a}: ${C_GREEN}${count_a}${C_RESET}"
        echo "  ${label_b}: ${C_GREEN}${count_b}${C_RESET}"
        if ((errors > 0)); then
                echo "  Errors: ${C_RED}${errors}${C_RESET}"
        else
                echo "  Errors: ${C_GREEN}${errors}${C_RESET}"
        fi
        print_rule "─"
}

