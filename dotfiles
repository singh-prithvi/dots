# Draw a screen header: a title bar with an optional breadcrumb, used by
# both full menus and one-shot action screens so they share a look.
#
# THIS USED TO CALL `clear`. It doesn't anymore. `clear` blanks the whole
# terminal and resets the cursor as a side effect — which is exactly the
# mechanism that caused the flicker you complained about: blank frame,
# then full frame, every single keypress, forever. `tput cup 0 0` gets
# the one thing we actually needed (cursor back at the top-left) without
# the accompanying screen-wide flash.
#
# This function only ever paints ITS OWN four lines and stops — it does
# not erase anything below itself. That's deliberate: it's called from
# render_menu_screen on EVERY arrow key, so anything it did beyond its
# own four lines would happen at keystroke frequency, not screen-change
# frequency, and you'd be right back to flickering. Whoever calls this
# and needs the rest of the screen guaranteed clean (begin_action_screen,
# show_interactive_menu) is responsible for doing that erase themselves,
# exactly once, at the point where a genuinely new screen begins — not
# in here.
draw_screen_header() {
        local title="$1"
        tput cup 0 0
        print_rule "─"
        print_centered "$title" "${C_BOLD}${C_ACCENT}"
        print_rule "─"
        echo
}

# Start a one-shot action screen (git status, a diff, sync output, etc).
#
# BUG YOU FOUND (image 2/3 — the full Git menu still sitting there behind
# "Commit message:"): this used to be a one-line pass-through to
# draw_screen_header and nothing else. draw_screen_header only paints
# ITS OWN four lines (rule, title, rule, blank) — it was never told to
# touch anything below that, on purpose, because render_menu_screen also
# calls draw_screen_header on every single arrow-key press, and erasing
# the whole screen on every arrow key is the exact flicker you started
# this whole refactor to get rid of.
#
# But action screens aren't like menus — begin_action_screen runs ONCE
# per screen, not once per keystroke, so there's no flicker risk in
# giving it its own one-time `tput ed` right here, right after the
# header, before a single byte of the screen's actual content (a git
# diff, a commit prompt, whatever) gets drawn on top of it. That's the
# difference between "erase once when the screen changes" (fine, cheap,
# invisible) and "erase on every keystroke" (the bug you originally
# complained about). Same instruction, wildly different frequency.
begin_action_screen() {
        draw_screen_header "$1"
        tput ed
}

# Repository summary block shown under the title on the main menu:
# path, current branch, clean/dirty, and how many paths are tracked.
# Nothing here is fatal if the repo doesn't exist yet — the point of
# this block is partly to make that obvious at a glance, since you
# will absolutely forget you never ran `git init`.
print_status_block() {
        local branch status_label status_color

        branch=$(current_branch)

        if is_repo_clean; then
                status_label="Clean"
                status_color="$C_GREEN"
        else
                status_label="Dirty"
                status_color="$C_YELLOW"
        fi

        echo "  ${C_DIM}Repository${C_RESET}"
        if repo_is_valid; then
                echo "  ${C_GREEN}${ICON_OK}${C_RESET} $(shorten_path "$REPO_DIR")"
        else
                echo "  ${C_RED}${ICON_ERR}${C_RESET} $(shorten_path "$REPO_DIR") ${C_DIM}(not found)${C_RESET}"
        fi
        echo
        echo "  ${C_DIM}Branch${C_RESET}"
        echo "  ${branch}"
        echo
        echo "  ${C_DIM}Status${C_RESET}"
        echo "  ${status_color}${status_label}${C_RESET}"
        echo
        echo "  ${C_DIM}Tracked${C_RESET}"
        echo "  ${#DIRECTORIES[@]} folders"
        echo "  ${#FILES[@]} files"
}

# Render one full menu screen: header, optional status block, the item
# list with the current selection highlighted, and a footer key legend.
# This is pure rendering — no input handling lives here, a boundary
# you've apparently managed to respect exactly once in this codebase.
#
# NO erase call lives in here anymore, on purpose. This function runs on
# EVERY arrow key while a menu is open — that's the highest-frequency
# redraw in the whole app, and it's exactly the path the original
# flicker complaint was about. Within one show_interactive_menu session
# the title, status block, and item list are all the same length every
# single time (only which item is highlighted changes), so overwriting
# in place is already leftover-free — there is nothing here that ever
# needs erasing between keystrokes. The one-time erase for when the
# screen ACTUALLY changes shape lives in show_interactive_menu, once,
# before this loop starts — not in here, where it would run every time
# you tapped an arrow key.
render_menu_screen() {
        local title="$1" show_status="$2" selected="$3"
        shift 3
        local -a items=("$@")

        draw_screen_header "$title"

        if [[ "$show_status" == "1" ]]; then
                print_status_block
                echo
        fi

        local i=0 item
        for item in "${items[@]}"; do
                if ((i == selected)); then
                        printf '  %s%s❯ %s%s\n' "$C_ACCENT" "$C_BOLD" "$item" "$C_RESET"
                else
                        printf '    %s%s%s\n' "$C_DIM" "$item" "$C_RESET"
                fi
                ((++i))
        done

        echo
        print_rule "─"
        printf '  %s↑↓/jk%s Move   %sEnter%s Select   %sEsc%s Back   %sq%s Quit   %s?%s Help\n' \
                "$C_BOLD" "$C_RESET" "$C_BOLD" "$C_RESET" "$C_BOLD" "$C_RESET" "$C_BOLD" "$C_RESET" "$C_BOLD" "$C_RESET"
}

# The single, reusable interactive menu. Every menu in this app — main,
# Git, Tracked Files, Settings, Theme, Branches — calls this instead of
# hand-rolling its own selection loop, because six copies of the same
# 40-line while-loop is a crime scene, not an architecture.
#
# Sets the global MENU_RESULT to one of:
#   an integer index into the items you passed in, or
#   "BACK" (Esc / h)
#   '?' (help) is handled internally and never leaks out — it shows the
#     help screen and simply redraws this same menu afterward.
#   'q' exits the whole application immediately and never returns here.
#
# Note for future-you doing the "redraw only what changed" pass: this is
# where you'll want to stop calling render_menu_screen() on every arrow
# key and instead track `selected` vs. the previous selection, moving the
# cursor to just those two item lines and repainting only them. The loop
# below already isolates every state transition into one `case`, so that
# change stays local to this function — you're welcome, past you did you
# a favor for once.
#
# BUG YOU FOUND (image 1 — "Statusry", the mashed-up title): this is the
# other half of the fix that lives in begin_action_screen. Every call to
# show_interactive_menu is a genuinely NEW screen — different title,
# different item count, maybe a status block that wasn't there before —
# so, exactly ONCE, before the loop even starts, we erase whatever the
# previous screen left behind. After that the loop is free to hammer
# render_menu_screen on every arrow key without ever touching `tput ed`
# again, because nothing about this menu's shape changes between one
# keystroke and the next.
show_interactive_menu() {
        local title="$1" show_status="$2"
        shift 2
        local -a items=("$@")
        local count=${#items[@]}
        local selected=0
        local key

        tput cup 0 0
        tput ed

        while true; do
                render_menu_screen "$title" "$show_status" "$selected" "${items[@]}"
                key=$(read_key)

                case "$key" in
                UP | KEY:k)
                        selected=$(((selected - 1 + count) % count))
                        ;;
                DOWN | KEY:j)
                        selected=$(((selected + 1) % count))
                        ;;
                ENTER)
                        MENU_RESULT="$selected"
                        return 0
                        ;;
                ESCAPE | KEY:h)
                        MENU_RESULT="BACK"
                        return 0
                        ;;
                KEY:q)
                        cleanup_and_exit 0
                        ;;
                'KEY:?')
                        show_help_screen
                        ;;
                RESIZE)
                        # A resize mid-menu is actually the easy case: the
                        # items and title are still known and unchanged, so
                        # a clear + let the loop redraw on the next
                        # iteration is a full, correct recovery — not a
                        # best-effort one like the other RESIZE handlers.
                        clear
                        ;;
                *)
                        : # ignore anything we don't recognize and keep waiting
                        ;;
                esac
        done
}

# The help screen, reachable with '?' from literally any menu. It's a
# dead end by design: read, absorb, press a key, go back to whatever you
# were doing. No navigation logic needed beyond that — a rare piece of
# this app that isn't secretly a state machine in disguise.
#
# Uses begin_action_screen, not draw_screen_header directly — this is
# popped open from the MIDDLE of a menu's render loop (see show_help_screen's
# only caller, inside show_interactive_menu's case statement), which means
# there's a full menu's worth of items and footer sitting on screen right
# up until this draws over it. begin_action_screen's one-time erase is
# exactly what makes sure the help text isn't reading like a ransom note
# spliced into whatever menu you summoned it from.
show_help_screen() {
        begin_action_screen "Help"

        echo "  ${C_BOLD}Navigation${C_RESET}"
        echo "    ↑ / k        Move selection up"
        echo "    ↓ / j        Move selection down"
        echo "    Enter        Select the highlighted item"
        echo "    Esc / h      Go back one menu"
        echo "    q            Quit the application, from anywhere"
        echo "    ?            Show this help screen"
        echo
        echo "  ${C_BOLD}What this tool does${C_RESET}"
        echo "    Sync copies tracked files FROM \$HOME INTO the git repository."
        echo "    Restore copies them the other way — repository back to \$HOME."
        echo "    Everything else is just Git, pointed at that repository."
        echo
        print_rule "─"
        pause_for_return
}

