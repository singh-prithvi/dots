        C_RESET=$'\033[0m'
        C_BOLD=$'\033[1m'
        C_DIM=$'\033[2m'
else
        # Not a terminal (piped to a file, redirected, etc). Degrade to plain
        # text rather than filling a log file with escape-code soup nobody
        # asked to read.
        C_RESET=""
        C_BOLD=""
        C_DIM=""
fi
C_ACCENT=""
C_GREEN=""
C_RED=""
C_YELLOW=""
C_BLUE=""

# Swap the themeable palette. Called once at startup, and again whenever
# you get bored at 1am and decide the app needs "a different vibe."
#
# "default" is plain 8-color ANSI: it works literally everywhere, including
# that one TTY without a GPU you SSH into at 3am to fix something on fire
# that you started.
#
# "mocha" is Catppuccin Mocha, using 24-bit truecolor escapes, because
# obviously you couldn't ship a terminal tool in 2024+ without it. It was
# never optional, was it.
apply_theme() {
        local theme="${1:-default}"

        if [[ ! -t 1 ]]; then
                C_ACCENT=""
                C_GREEN=""
                C_RED=""
                C_YELLOW=""
                C_BLUE=""
                return 0
        fi

        case "$theme" in
        mocha)
                C_ACCENT=$'\033[38;2;203;166;247m' # Mauve
                C_GREEN=$'\033[38;2;166;227;161m'  # Green
